class Solution:
    def maxProfit(self, prices: List[int], fee: int) -> int:
        
        # rows, cols = len(prices), len(prices)

        # tmp = [0]
        # idx = 0
        # for i in range(rows-1, -1, -1):
        #     row_max = 0
        #     for j in range(cols-1, -1, -1):
        #         if j > i:
        #             dp = prices[j] - prices[i] - fee + tmp[cols-j-1]
        #             if row_max < dp:
        #                 row_max = dp
        #     tmp.append(max(row_max, tmp[idx]))
        #     idx += 1

        # return tmp[-1]

        own = -prices[0]
        profit = 0 

        for price in prices:
            own = max(own, profit - price)
            profit = max(profit, own + price - fee)

        return profit
        
